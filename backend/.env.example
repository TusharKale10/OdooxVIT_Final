PORT=4000
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=appointment_app
JWT_SECRET=change_me_super_secret_key
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173

# Public-facing app URL used in email links (password reset, etc.)
APP_URL=http://localhost:5173

# SMTP (optional). When omitted, the app uses Ethereal (a free dev SMTP) and
# logs the preview URL to the server console. To send real mail, fill these in.
# Example with Gmail App Password:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=465
#   SMTP_SECURE=true
#   SMTP_USER=you@gmail.com
#   SMTP_PASS=your_16_char_app_password
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Appointly <noreply@appointly.local>
